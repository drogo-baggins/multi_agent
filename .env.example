# pi-agent Environment Configuration
# Copy this file to .env and uncomment/fill in the values you need.
# Existing environment variables take precedence over .env values.

# LLM Provider API Keys
# PI toolkit supports many providers. Set the API key for your provider.
# Full list: https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/docs/providers.md
# Alternatively, use /login in the interactive session for OAuth-based providers.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=...
# VENICE_API_KEY=vnc-...

# Azure OpenAI (AZURE_OPENAI_API_KEY と合わせて設定)
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
# AZURE_OPENAI_RESOURCE_NAME=your-resource
# AZURE_OPENAI_DEPLOYMENT_NAME_MAP=gpt-4o=my-gpt4o,gpt-4=my-gpt4

# Per-Agent Model Configuration
# Each agent can use a different provider/model. Format: "provider/model-id"
# If not set, all agents use the main session model (selected via /model or --model).
# WORKER_MODEL=venice/qwen3-235b
# MANAGER_MODEL=anthropic/claude-sonnet-4-20250514
# PROXY_MODEL=openai/gpt-4o

# SearXNG (Web Search)
# Requires a running SearXNG instance with JSON format enabled.
# Start with: .\scripts\searxng-start.ps1 (Windows) or ./scripts/searxng-start.sh (Linux)
# SEARXNG_URL=http://localhost:8888
# SEARXNG_TIMEOUT_MS=30000
# SEARXNG_MAX_RESULTS=10
